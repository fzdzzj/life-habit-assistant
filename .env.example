# Local-only configuration template.
# Copy this file to .env and replace the placeholder values before starting the application.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=life_habit_assistant
DB_USERNAME=root
DB_PASSWORD=replace-with-your-local-password
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_EXPIRATION_HOURS=24
# Set true only for the first migration of an existing manually-created schema.
# Keep false for a new empty database.
FLYWAY_BASELINE_ON_MIGRATE=false
